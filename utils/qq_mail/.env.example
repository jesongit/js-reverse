# QQ 邮箱 IMAP/SMTP 配置
# 复制此文件为 .env，填入真实值后删除本行注释
#
# 授权码获取方式：
#   QQ 邮箱网页 → 设置 → 账户 → POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务
#   → 开启 IMAP/SMTP 服务 → 生成授权码

# ── 必填（必须填写真实值）──────────────────────────────
IMAP_USER     = your_qq_account@qq.com
IMAP_PASSWORD = your_imap_authorization_code

# ── 可选（不填则用默认值）──────────────────────────────
# IMAP_HOST    = imap.qq.com
# IMAP_PORT    = 993
#
# SMTP_USER/SMTP_PASSWORD 可单独设置，不填则复用 IMAP_USER/IMAP_PASSWORD
# SMTP_HOST    = smtp.qq.com
# SMTP_PORT    = 587      # 优先 STARTTLS；备用 465（SSL）
# IDLE_TIMEOUT = 1500     # IDLE 单次等待超时（秒），建议 ≤ 1740（29分钟）
# RECONNECT_DELAY = 5     # 断线重连前等待秒数
# MAX_RECONNECT   = 10    # 最大连续重连次数，设为 0 则无限重连
